#!/usr/bin/env bash
# deepclaude — Claude Code via DeepSeek/OpenRouter proxy
# Usage: deepclaude [--backend ds|or|cx|deepseek|minimax|anthropic] [--status|--cost|--benchmark|--switch <b>|--help] [-- <claude-args>]

set -eu

# --- Auto-detect backend models from proxy /_/presets ---
#
# Fetches GET <proxy>/_/presets ONCE, parses the (backend, tier) → model
# map, then locally resolves each tier by the client-side table:
#
#   t1 -> OPUS_MODEL
#   t2 -> SONNET_MODEL
#   t3 -> HAIKU_MODEL
#   t4 -> SUBAGENT_MODEL
#
# The proxy uses abstract tier labels (t1, t2, ...). The mapping from
# tier label to deepclaude slot is hardcoded here. Other clients (Pi,
# Codex) have their own tables. The deepclaude case name == the proxy
# backend name (e.g. `deepseek`, `minimax`) — no mapping function.

# Map abstract tier label -> deepclaude slot name.
_deepclaude_tier_to_slot() {
    case "$1" in
        t1) echo OPUS_MODEL ;;
        t2) echo SONNET_MODEL ;;
        t3) echo HAIKU_MODEL ;;
        t4) echo SUBAGENT_MODEL ;;
        *)  return 1 ;;
    esac
}

# Fetch /_/presets and emit lines of "<tier>=<model>" on stdout for
# the target backend. Returns non-zero (and empty stdout) on any failure.
_deepclaude_fetch_presets() {
    local url="$1/_/presets"
    local raw
    raw=$(curl --max-time 3 -fsS "$url" 2>/dev/null) || return 1
    python3 -c '
import sys, json
try:
    data = json.loads(sys.stdin.read())
    target_backend = sys.argv[1]
    presets = data.get("presets", {}).get(target_backend, {})
    for tier, model in presets.items():
        print(tier + "=" + model)
except Exception:
    sys.exit(1)
' "$2" <<<"$raw"
}

SOURCE="${BASH_SOURCE[0]:-$0}"
while [ -L "$SOURCE" ]; do
    DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
    SOURCE="$(readlink "$SOURCE")"
    case "$SOURCE" in
        /*) ;;
        *) SOURCE="$DIR/$SOURCE" ;;
    esac
done
SCRIPT_DIR="$(cd "$(dirname "$SOURCE")" && pwd)"
PROXY_SCRIPT="$SCRIPT_DIR/proxy/start-proxy.js"
PROXY_PORT="${DEEPCLAUDE_PROXY_PORT:-3200}"
PROXY_PID=""
HEARTBEAT_PID=""
PROXY_LOG="${TMPDIR:-/tmp}/deepclaude-proxy.$$"
SESSION_ID="${DEEPCLAUDE_SESSION_ID:-}"
HEARTBEAT_INTERVAL="${DEEPCLAUDE_PROXY_HEARTBEAT_INTERVAL:-30}"

# --- Helpers ---

mask_key() {
    local k="$1"
    if [[ -z "$k" ]]; then echo "MISSING"; else echo "set (****${k: -4})"; fi
}

clean_path() {
    local exclude1="$1" exclude2="$HOME/bin" result="" saved_IFS="$IFS"
    IFS=:
    for p in $PATH; do
        [ "$p" = "$exclude1" ] && continue
        [ "$p" = "$exclude2" ] && continue
        [ -z "$p" ] && continue
        result="${result:+$result:}$p"
    done
    IFS="$saved_IFS"
    echo "$result"
}

# --- Backend resolution (single source of truth for model names) ---

resolve_backend() {
    case "$BACKEND" in
        ds)
            [ -n "${DEEPSEEK_API_KEY:-}" ] || { echo "deepclaude: DEEPSEEK_API_KEY is not set" >&2; exit 1; }
            TARGET_URL="https://api.deepseek.com/anthropic"
            TARGET_KEY="$DEEPSEEK_API_KEY"
            OPUS_MODEL="deepseek-v4-pro"
            SONNET_MODEL="deepseek-v4-pro"
            HAIKU_MODEL="deepseek-v4-flash"
            SUBAGENT_MODEL="deepseek-v4-flash"
            ;;
        openrouter)
            [ -n "${OPENROUTER_API_KEY:-}" ] || { echo "deepclaude: OPENROUTER_API_KEY is not set" >&2; exit 1; }
            TARGET_URL="https://openrouter.ai/api/v1"
            TARGET_KEY="$OPENROUTER_API_KEY"
            OPUS_MODEL="deepseek/deepseek-v4-pro"
            SONNET_MODEL="deepseek/deepseek-v4-pro"
            HAIKU_MODEL="deepseek/deepseek-v4-pro"
            SUBAGENT_MODEL="deepseek/deepseek-v4-pro"
            ;;
        codex)
            [ -n "${OPENAI_API_KEY:-}" ] || { echo "deepclaude: OPENAI_API_KEY is not set" >&2; exit 1; }
            TARGET_URL="https://api.openai.com/v1"
            TARGET_KEY="$OPENAI_API_KEY"
            OPUS_MODEL="gpt-5.5"
            SONNET_MODEL="gpt-5.4"
            HAIKU_MODEL="gpt-5.4"
            SUBAGENT_MODEL="gpt-5.4"
            ;;
        deepseek)
            TARGET_URL="${DEEPSEEK_PROXY_URL:-https://proxy.lab.tf}"
            TARGET_KEY="${DEEPSEEK_PROXY_API_KEY:-unused}"
            if command -v python3 >/dev/null 2>&1; then
                presets=$(_deepclaude_fetch_presets "$TARGET_URL" deepseek 2>/dev/null || true)
                if [ -n "$presets" ]; then
                    while IFS='=' read -r tier model; do
                        slot=$(_deepclaude_tier_to_slot "$tier" 2>/dev/null || true)
                        if [ -n "$slot" ]; then
                            current="${!slot:-}"
                            if [ -z "$current" ]; then
                                eval "$slot=\$model"
                            fi
                        fi
                    done <<<"$presets"
                else
                    echo "[deepclaude] could not reach $TARGET_URL/_/presets, using hardcoded defaults" >&2
                fi
            else
                echo "[deepclaude] python3 not found, using hardcoded defaults" >&2
            fi
            OPUS_MODEL="${DEEPSEEK_OPUS_MODEL:-${OPUS_MODEL:-deepseek-v4-pro}}"
            SONNET_MODEL="${DEEPSEEK_SONNET_MODEL:-${SONNET_MODEL:-deepseek-v4-pro}}"
            HAIKU_MODEL="${DEEPSEEK_HAIKU_MODEL:-${HAIKU_MODEL:-deepseek-v4-flash}}"
            SUBAGENT_MODEL="${DEEPSEEK_SUBAGENT_MODEL:-${SUBAGENT_MODEL:-deepseek-v4-flash}}"
            ;;
        minimax)
            TARGET_URL="${MINIMAX_PROXY_URL:-https://proxy.lab.tf}"
            TARGET_KEY="${MINIMAX_PROXY_API_KEY:-unused}"
            if command -v python3 >/dev/null 2>&1; then
                presets=$(_deepclaude_fetch_presets "$TARGET_URL" minimax 2>/dev/null || true)
                if [ -n "$presets" ]; then
                    while IFS='=' read -r tier model; do
                        slot=$(_deepclaude_tier_to_slot "$tier" 2>/dev/null || true)
                        if [ -n "$slot" ]; then
                            current="${!slot:-}"
                            if [ -z "$current" ]; then
                                eval "$slot=\$model"
                            fi
                        fi
                    done <<<"$presets"
                else
                    echo "[deepclaude] could not reach $TARGET_URL/_/presets, using hardcoded defaults" >&2
                fi
            else
                echo "[deepclaude] python3 not found, using hardcoded defaults" >&2
            fi
            OPUS_MODEL="${MINIMAX_OPUS_MODEL:-${OPUS_MODEL:-MiniMax-M3}}"
            SONNET_MODEL="${MINIMAX_SONNET_MODEL:-${SONNET_MODEL:-MiniMax-M3}}"
            HAIKU_MODEL="${MINIMAX_HAIKU_MODEL:-${HAIKU_MODEL:-MiniMax-M2.7}}"
            SUBAGENT_MODEL="${MINIMAX_SUBAGENT_MODEL:-${SUBAGENT_MODEL:-MiniMax-M2.7}}"
            ;;
        anthropic)
            OPUS_MODEL=""
            SONNET_MODEL=""
            HAIKU_MODEL=""
            SUBAGENT_MODEL=""
            ;;
    esac
}

# --- Proxy lifecycle ---

cleanup_proxy() {
    if [ -n "$HEARTBEAT_PID" ] && kill -0 "$HEARTBEAT_PID" 2>/dev/null; then
        kill "$HEARTBEAT_PID" 2>/dev/null || true
        wait "$HEARTBEAT_PID" 2>/dev/null || true
    fi
    if [ -n "$SESSION_ID" ]; then
        curl -fsS -X POST "http://127.0.0.1:$PROXY_PORT/_proxy/session" \
            -d "action=stop&session=$SESSION_ID" >/dev/null 2>&1 || true
    fi
    if [ "${DEEPCLAUDE_STOP_PROXY_ON_EXIT:-0}" = "1" ] && [ -n "$PROXY_PID" ] && kill -0 "$PROXY_PID" 2>/dev/null; then
        kill "$PROXY_PID" 2>/dev/null || true
        wait "$PROXY_PID" 2>/dev/null || true
    fi
    rm -f "$PROXY_LOG"
}

start_heartbeat() {
    curl -fsS -X POST "http://127.0.0.1:$PROXY_PORT/_proxy/session" \
        -d "action=heartbeat&session=$SESSION_ID&pid=$$" >/dev/null 2>&1 || true
    (
        while :; do
            sleep "$HEARTBEAT_INTERVAL" || exit 0
            curl -fsS -X POST "http://127.0.0.1:$PROXY_PORT/_proxy/session" \
                -d "action=heartbeat&session=$SESSION_ID&pid=$$" >/dev/null 2>&1 || exit 0
        done
    ) &
    HEARTBEAT_PID=$!
}

trap cleanup_proxy EXIT INT TERM

# --- Commands ---

show_status() {
    echo ""
    echo "  deepclaude — Status"
    echo "  ==================="
    echo ""
    echo "  Keys:"
    echo "    DEEPSEEK_API_KEY:    $(mask_key "${DEEPSEEK_API_KEY:-}")"
    echo "    OPENROUTER_API_KEY:  $(mask_key "${OPENROUTER_API_KEY:-}")"
    echo "    OPENAI_API_KEY:       $(mask_key "${OPENAI_API_KEY:-}")"
    echo ""
    echo "  Backends:"
    echo "    deepclaude                  # DeepSeek V4 Pro (default)"
    echo "    deepclaude -b or            # OpenRouter"
    echo "    deepclaude -b cx            # OpenAI Codex (GPT-5.5/5.4)"
    echo "    deepclaude -b deepseek      # proxy.lab.tf / DeepSeek models (no local proxy)"
    echo "    deepclaude -b minimax       # proxy.lab.tf / MiniMax-M3 (no local proxy)"
    echo "    deepclaude -b anthropic     # Normal Claude Code"
    echo ""
    local ps
    ps=$(curl -sS "http://127.0.0.1:$PROXY_PORT/_proxy/status" 2>/dev/null) || ps=""
    if [[ -n "$ps" ]]; then
        echo "  Proxy: running"
        echo "    $ps"
    else
        echo "  Proxy: not running"
    fi
    echo ""
}

show_cost() {
    echo ""
    echo "  Pricing (per 1M tokens)"
    echo "  ======================="
    echo ""
    echo "  Provider        Input     Output    Cache Hit"
    echo "  ----------      -----     ------    ---------"
    echo "  DeepSeek        \$0.44     \$0.87     \$0.004"
    echo "  OpenRouter      \$0.44     \$0.87     (provider)"
    echo "  Codex (GPT-5)   \$5.00     \$30.00    (standard)"
    echo "  Anthropic       \$3.00     \$15.00    \$0.30"
    echo ""
}

show_help() {
    echo "deepclaude — Claude Code with cheap backends"
    echo ""
    echo "Usage: deepclaude [options] [-- <claude-args>]"
    echo ""
    echo "Options:"
    echo "  -b, --backend <ds|or|cx|deepseek|minimax|anthropic> Backend (default: deepseek)"
    echo ""
    echo "deepseek backend (proxy.lab.tf) per-tier overrides:"
    echo "  DEEPSEEK_OPUS_MODEL       (default: deepseek-v4-pro)"
    echo "  DEEPSEEK_SONNET_MODEL     (default: deepseek-v4-pro)"
    echo "  DEEPSEEK_HAIKU_MODEL      (default: deepseek-v4-flash)"
    echo "  DEEPSEEK_SUBAGENT_MODEL   (default: deepseek-v4-flash)"
    echo ""
    echo "minimax backend (proxy.lab.tf) per-tier overrides:"
    echo "  MINIMAX_OPUS_MODEL        (default: MiniMax-M3)"
    echo "  MINIMAX_SONNET_MODEL      (default: MiniMax-M3)"
    echo "  MINIMAX_HAIKU_MODEL       (default: MiniMax-M2.7)"
    echo "  MINIMAX_SUBAGENT_MODEL    (default: MiniMax-M2.7)"
    echo "  -s, --switch <backend>            Switch proxy mid-session"
    echo "  --status                           Show keys and proxy status"
    echo "  --cost                             Pricing comparison"
    echo "  --benchmark                        Latency test"
    echo "  -h, --help                         This help"
    echo ""
    echo "Environment:"
    echo "  DEEPSEEK_API_KEY      DeepSeek API key"
    echo "  OPENROUTER_API_KEY    OpenRouter API key"
    echo "  DEEPCLAUDE_PROXY_PORT  Proxy port (default: 3200)"
}

do_switch() {
    local backend="$1"
    case "$backend" in
        ds)            backend="ds" ;;
        or|openrouter) backend="openrouter" ;;
        cx|codex)      backend="codex" ;;
        anthropic)     backend="anthropic" ;;
        deepseek|minimax) echo "  $backend mode bypasses the local proxy; relaunch with: deepclaude -b $backend" >&2; exit 1 ;;
        llm|m3)        echo "  $backend is no longer supported; use -b deepseek or -b minimax instead" >&2; exit 1 ;;
        *) echo "deepclaude: unknown backend '$backend'" >&2; exit 1 ;;
    esac
    local resp
    resp=$(curl -sS -X POST "http://127.0.0.1:$PROXY_PORT/_proxy/mode" -d "backend=$backend" 2>/dev/null) || {
        echo "deepclaude: proxy not running. Start with: deepclaude" >&2
        exit 1
    }
    echo "  Switched: $resp"
}

run_benchmark() {
    echo ""
    echo "  Latency Benchmark (1 request each)"
    echo "  ================================="
    for name in deepseek openrouter codex; do
        local url="" key="" model="" auth_header="x-api-key"
        case "$name" in
            deepseek)
                url="https://api.deepseek.com/anthropic"
                key="${DEEPSEEK_API_KEY:-}"
                model="deepseek-v4-pro"
                ;;
            openrouter)
                url="https://openrouter.ai/api/v1"
                key="${OPENROUTER_API_KEY:-}"
                model="deepseek/deepseek-v4-pro"
                ;;
            codex)
                url="https://api.openai.com/v1"
                key="${OPENAI_API_KEY:-}"
                model="gpt-5.4"
                auth_header="Authorization: Bearer"
                ;;
        esac
        if [[ -z "$key" ]]; then echo "  $name: SKIP (no key)"; continue; fi
        local start_ms
        start_ms=$(date +%s%3N 2>/dev/null || python3 -c 'import time;print(int(time.time()*1000))')
        local status
        status=$(curl -s -o /dev/null -w "%{http_code}" -X POST "$url/chat/completions" \
            -H "$auth_header: $key" -H "content-type: application/json" \
            -d "{\"model\":\"$model\",\"max_tokens\":32,\"messages\":[{\"role\":\"user\",\"content\":\"Reply: ok\"}]}" \
            --max-time 30 2>/dev/null || echo "timeout")
        local end_ms
        end_ms=$(date +%s%3N 2>/dev/null || python3 -c 'import time;print(int(time.time()*1000))')
        local elapsed=$((end_ms - start_ms))
        if [[ "$status" == "200" ]]; then
            echo "  $name: OK (${elapsed}ms)"
        else
            echo "  $name: FAIL ($status, ${elapsed}ms)"
        fi
    done
    echo ""
}

# --- Launch ---

launch() {
    resolve_backend

    # Note: bash's && binds tighter than ||, so explicit grouping is required.
    if [ -t 2 ] && { [ "$BACKEND" = "deepseek" ] || [ "$BACKEND" = "minimax" ]; }; then
        echo "[deepclaude] backend=$BACKEND resolved: opus=$OPUS_MODEL sonnet=$SONNET_MODEL haiku=$HAIKU_MODEL subagent=$SUBAGENT_MODEL" >&2
    fi

    if [ "$BACKEND" = "anthropic" ]; then
        echo "  Launching Claude Code (Anthropic direct)..."
        unset ANTHROPIC_BASE_URL ANTHROPIC_AUTH_TOKEN
        unset ANTHROPIC_DEFAULT_OPUS_MODEL ANTHROPIC_DEFAULT_SONNET_MODEL
        unset ANTHROPIC_DEFAULT_HAIKU_MODEL CLAUDE_CODE_SUBAGENT_MODEL
        CLEANED_PATH="$(clean_path "$SCRIPT_DIR")"
        PATH="$CLEANED_PATH" exec claude "$@"
    fi

    if [ "$BACKEND" = "deepseek" ] || [ "$BACKEND" = "minimax" ]; then
        echo "  Launching Claude Code (via proxy.lab.tf)..."
        echo "" >&2
        echo "  ▸ backend : $BACKEND" >&2
        echo "  ▸ opus    : $OPUS_MODEL" >&2
        echo "  ▸ haiku   : $HAIKU_MODEL" >&2
        echo "" >&2
        export ANTHROPIC_BASE_URL="$TARGET_URL"
        export ANTHROPIC_AUTH_TOKEN="$TARGET_KEY"
        export ANTHROPIC_DEFAULT_OPUS_MODEL="$OPUS_MODEL"
        export ANTHROPIC_DEFAULT_SONNET_MODEL="$SONNET_MODEL"
        export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
        export CLAUDE_CODE_SUBAGENT_MODEL="$SUBAGENT_MODEL"
        CLEANED_PATH="$(clean_path "$SCRIPT_DIR")"
        PATH="$CLEANED_PATH" exec claude "$@"
    fi

    # Start proxy if not running
    local ps
    ps=$(curl -sS "http://127.0.0.1:$PROXY_PORT/_proxy/status" 2>/dev/null) || ps=""
    if [ -n "$ps" ]; then
        case "$ps" in
            *'"live_sessions"'*) ;;
            *)
                echo "deepclaude: existing proxy on 127.0.0.1:$PROXY_PORT is too old (no session support)" >&2
                echo "deepclaude: stop it, reinstall this plugin, then try again" >&2
                exit 1
                ;;
        esac
        echo "deepclaude: using existing proxy on 127.0.0.1:$PROXY_PORT"
    else
        CHEAPCLAUDE_TARGET_URL="$TARGET_URL" CHEAPCLAUDE_API_KEY="$TARGET_KEY" \
            node "$PROXY_SCRIPT" >"$PROXY_LOG" 2>&1 &
        PROXY_PID=$!

        local i=0
        while [ "$i" -lt 50 ]; do
            if curl -fsS "http://127.0.0.1:$PROXY_PORT/_proxy/status" >/dev/null 2>&1; then
                break
            fi
            if ! kill -0 "$PROXY_PID" 2>/dev/null; then
                echo "deepclaude: proxy failed to start" >&2
                sed -n '1,80p' "$PROXY_LOG" >&2
                exit 1
            fi
            i=$((i + 1))
            sleep 0.1
        done

        if [ "$i" -ge 50 ]; then
            echo "deepclaude: proxy did not become ready on 127.0.0.1:$PROXY_PORT" >&2
            sed -n '1,80p' "$PROXY_LOG" >&2
            exit 1
        fi

        echo "deepclaude: started proxy on 127.0.0.1:$PROXY_PORT (backend: $BACKEND)"
    fi

    # Set proxy mode for this session
    curl -fsS -X POST "http://127.0.0.1:$PROXY_PORT/_proxy/mode" \
        -d "backend=$BACKEND&session=$SESSION_ID" >/dev/null || {
        echo "deepclaude: failed to switch proxy to $BACKEND" >&2
        exit 1
    }

    start_heartbeat

    export ANTHROPIC_BASE_URL="http://127.0.0.1:$PROXY_PORT"
    export DEEPCLAUDE_SESSION_ID="$SESSION_ID"
    export ANTHROPIC_AUTH_TOKEN="$SESSION_ID"
    export ANTHROPIC_DEFAULT_OPUS_MODEL="$OPUS_MODEL"
    export ANTHROPIC_DEFAULT_SONNET_MODEL="$SONNET_MODEL"
    export ANTHROPIC_DEFAULT_HAIKU_MODEL="$HAIKU_MODEL"
    export CLAUDE_CODE_SUBAGENT_MODEL="$SUBAGENT_MODEL"

    echo "" >&2
    echo "  ▸ backend : $BACKEND" >&2
    echo "  ▸ opus    : $OPUS_MODEL" >&2
    echo "  ▸ haiku   : $HAIKU_MODEL" >&2
    echo "" >&2

    CLEANED_PATH="$(clean_path "$SCRIPT_DIR")"
    PATH="$CLEANED_PATH" exec claude "$@"
}

# --- Main ---

# Detect how we were invoked
INVOKED_AS="$(basename "$0")"

# Fetch API keys from 1Password if available
if [ -z "${DEEPSEEK_API_KEY:-}" ] && [ -x "$HOME/bin/op" ]; then
    eval "$("$HOME/bin/op" env deepseek --export 2>/dev/null || true)"
fi
if [ -z "${OPENROUTER_API_KEY:-}" ] && [ -x "$HOME/bin/op" ]; then
    eval "$("$HOME/bin/op" env openrouter --export 2>/dev/null || true)"
fi

export CLAUDE_CODE_DISABLE_NONESSENTIAL_TRAFFIC=1
export CLAUDE_CODE_DISABLE_NONSTREAMING_FALLBACK=1

BACKEND="${DEEPCLAUDE_DEFAULT_BACKEND:-deepseek}"
ACTION="launch"
SWITCH_BACKEND=""
PASSTHROUGH_ARGS=()

while [ $# -gt 0 ]; do
    case "$1" in
        --status)
            ACTION="status"
            shift
            ;;
        --cost)
            ACTION="cost"
            shift
            ;;
        --benchmark)
            ACTION="benchmark"
            shift
            ;;
        --help|-h)
            ACTION="help"
            shift
            ;;
        --switch|-s)
            ACTION="switch"
            SWITCH_BACKEND="$2"
            shift 2
            ;;
        --backend|-b)
            case "$2" in
                ds)            BACKEND="ds" ;;
                or|openrouter) BACKEND="openrouter" ;;
                cx|codex)      BACKEND="codex" ;;
                deepseek)      BACKEND="deepseek" ;;
                minimax)       BACKEND="minimax" ;;
                anthropic)     BACKEND="anthropic" ;;
                llm)           echo "  -b llm is no longer supported; use -b deepseek instead" >&2; exit 2 ;;
                m3)            echo "  -b m3 is no longer supported; use -b minimax instead" >&2; exit 2 ;;
                *) echo "deepclaude: unknown backend '$2'" >&2; exit 2 ;;
            esac
            shift 2
            ;;
        *)
            PASSTHROUGH_ARGS+=("$1")
            shift
            ;;
    esac
done

# Restore passthrough args for claude
set -- "${PASSTHROUGH_ARGS[@]}"

# If invoked as "claude", always launch transparently
if [ "$INVOKED_AS" = "claude" ]; then
    ACTION="launch"
fi

if [ -z "$SESSION_ID" ]; then
    if command -v uuidgen >/dev/null 2>&1; then
        SESSION_ID="dcx_$(uuidgen | tr '[:upper:]' '[:lower:]')"
    else
        SESSION_ID="dcx_$(date +%s)_$$"
    fi
fi

# Commands that don't need a proxy
case "$ACTION" in
    status)    show_status ;;
    cost)      show_cost ;;
    benchmark) run_benchmark ;;
    help)      show_help ;;
    switch)    do_switch "$SWITCH_BACKEND" ;;
    launch)    launch "$@" ;;
esac
